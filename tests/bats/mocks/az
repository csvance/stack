#!/usr/bin/env bash
# Mock az CLI for bats tests. Persists state under $MOCK_AZ_STATE_DIR (default
# $BATS_TEST_TMPDIR/az-state).
#
# Supports the subset of `az` invocations that lib/az_helpers.sh emits.

set -euo pipefail
IFS=$'\n\t'

state="${MOCK_AZ_STATE_DIR:-${BATS_TEST_TMPDIR:-/tmp}/az-state}"
mkdir -p "$state"
counter="$state/counter"
[[ -f "$counter" ]] || echo 0 > "$counter"

# Parse args: stash --foo VAL pairs in an associative array; remember positional.
declare -A flags=()
positional=()
i=0
while (( $# > 0 )); do
    case "$1" in
        --output)         flags[output]="$2"; shift 2 ;;
        --organization)   flags[org]="$2"; shift 2 ;;
        --project)        flags[project]="$2"; shift 2 ;;
        --repository)     flags[repo]="$2"; shift 2 ;;
        --source-branch)  flags[source]="$2"; shift 2 ;;
        --target-branch)  flags[target]="$2"; shift 2 ;;
        --title)          flags[title]="$2"; shift 2 ;;
        --description)    flags[description]="$2"; shift 2 ;;
        --status)         flags[status]="$2"; shift 2 ;;
        --id)             flags[id]="$2"; shift 2 ;;
        --name)           flags[name]="$2"; shift 2 ;;
        --only-show-errors|-o) shift ;;
        --) shift; break ;;
        *) positional+=("$1"); shift ;;
    esac
done

next_id() {
    local n
    n="$(cat "$counter")"
    n=$((n + 1))
    echo "$n" > "$counter"
    echo "$n"
}

pr_file_for() {
    printf '%s/pr-%s.json\n' "$state" "$1"
}

write_pr() {
    local id="$1" json="$2"
    printf '%s\n' "$json" > "$(pr_file_for "$id")"
}

read_pr() {
    local id="$1"
    local f; f="$(pr_file_for "$id")"
    [[ -f "$f" ]] || return 1
    cat "$f"
}

list_all_prs() {
    local f
    local out='[]'
    for f in "$state"/pr-*.json; do
        [[ -f "$f" ]] || continue
        out="$(jq -c --slurpfile p "$f" '. + [$p[0]]' <<<"$out")"
    done
    printf '%s\n' "$out"
}

# Dispatch.
sub="${positional[0]:-}"
arg1="${positional[1]:-}"
arg2="${positional[2]:-}"

case "$sub" in
    account)
        case "$arg1" in
            show)
                printf '{"user":{"name":"mock"},"id":"mock-sub"}\n'
                exit 0
                ;;
        esac
        ;;
    extension)
        case "$arg1" in
            show)
                if [[ "${flags[name]:-}" == "azure-devops" ]]; then
                    printf '{"name":"azure-devops","version":"mock"}\n'
                    exit 0
                fi
                exit 1
                ;;
        esac
        ;;
    repos)
        case "$arg1" in
            show)
                # az repos show: auth/reachability probe. Mock always succeeds.
                printf '{"id":"mock-repo","name":"%s"}\n' "${flags[repo]:-mock}"
                exit 0
                ;;
            pr)
                case "$arg2" in
                    create)
                        id="$(next_id)"
                        json="$(jq -c -n \
                            --argjson id "$id" \
                            --arg source "${flags[source]:-}" \
                            --arg target "${flags[target]:-}" \
                            --arg title  "${flags[title]:-}" \
                            '{pullRequestId: $id, sourceRefName: $source, targetRefName: $target, title: $title, status: "active", url: ("mock://pr/" + ($id|tostring))}')"
                        write_pr "$id" "$json"
                        printf '%s\n' "$json"
                        exit 0
                        ;;
                    update)
                        id="${flags[id]:?--id required for update}"
                        existing="$(read_pr "$id")" || { echo "pr $id not found" >&2; exit 1; }
                        updated="$existing"
                        if [[ -n "${flags[title]:-}" ]]; then
                            updated="$(jq -c --arg t "${flags[title]}" '.title = $t' <<<"$updated")"
                        fi
                        if [[ -n "${flags[target]:-}" ]]; then
                            updated="$(jq -c --arg t "${flags[target]}" '.targetRefName = $t' <<<"$updated")"
                        fi
                        if [[ -n "${flags[status]:-}" ]]; then
                            updated="$(jq -c --arg s "${flags[status]}" '.status = $s' <<<"$updated")"
                        fi
                        write_pr "$id" "$updated"
                        printf '%s\n' "$updated"
                        exit 0
                        ;;
                    show)
                        id="${flags[id]:?--id required for show}"
                        read_pr "$id"
                        exit 0
                        ;;
                    list)
                        all="$(list_all_prs)"
                        if [[ -n "${flags[source]:-}" ]]; then
                            all="$(jq -c --arg s "${flags[source]}" '[.[] | select(.sourceRefName == $s)]' <<<"$all")"
                        fi
                        printf '%s\n' "$all"
                        exit 0
                        ;;
                esac
                ;;
        esac
        ;;
esac

echo "mock-az: unrecognized command: $sub $arg1 $arg2 (flags: ${!flags[*]})" >&2
exit 1
