#!/usr/bin/env bash
# stack sync: rebase the entire stack onto a moved base ref.

set -euo pipefail
IFS=$'\n\t'

: "${STACK_HOME:?stack-sync must be invoked via the stack dispatcher}"

# shellcheck source=../lib/common.sh
source "$STACK_HOME/lib/common.sh"
# shellcheck source=../lib/git_helpers.sh
source "$STACK_HOME/lib/git_helpers.sh"
# shellcheck source=../lib/manifest.sh
source "$STACK_HOME/lib/manifest.sh"
# shellcheck source=../lib/branchless.sh
source "$STACK_HOME/lib/branchless.sh"
# shellcheck source=../lib/backup.sh
source "$STACK_HOME/lib/backup.sh"
# shellcheck source=../lib/verify.sh
source "$STACK_HOME/lib/verify.sh"
# shellcheck source=../lib/prompt.sh
source "$STACK_HOME/lib/prompt.sh"
# shellcheck source=../lib/conflict.sh
source "$STACK_HOME/lib/conflict.sh"

usage() {
    cat <<'EOF'
Usage: stack sync [--base-ref <ref>] [--no-fetch]

Fetch origin and rebase the entire stack onto the moved base ref. Conflicts
are resolved via PyCharm. The manifest is updated with the new base SHA and
each branch's new commit_sha.

Options:
  --base-ref <ref>   Override the manifest's base_ref (e.g. "origin/master")
  --no-fetch         Skip `git fetch origin`; use the base ref as it stands locally
EOF
}

base_ref_override=''
do_fetch=1
remaining=()
while (( $# > 0 )); do
    case "$1" in
        --base-ref)     shift; base_ref_override="${1:?--base-ref requires a value}" ;;
        --base-ref=*)   base_ref_override="${1#--base-ref=}" ;;
        --no-fetch)     do_fetch=0 ;;
        -h|--help)      usage; exit 0 ;;
        *)              remaining+=("$1") ;;
    esac
    shift
done

stack::parse_global_flags "${remaining[@]:-}"
stack::preflight_repo
stack::resolve_manifest
branchless::preflight
manifest::load

if ! git::working_tree_clean; then
    stack::die "working tree dirty or operation in progress; commit/stash first"
fi

base_ref="$base_ref_override"
if [[ -z "$base_ref" ]]; then
    base_ref="$(manifest::base_ref)"
fi
[[ -n "$base_ref" ]] || stack::die "manifest has no base_ref and --base-ref not provided"

# Normalize: if user passed "master" assume origin/master.
if [[ "$base_ref" != */* ]]; then
    base_ref="origin/$base_ref"
fi
# The remote-side name we'll fetch (e.g. master from origin/master).
remote_branch="${base_ref#origin/}"

if (( do_fetch )); then
    stack::info "fetching origin/$remote_branch..."
    if [[ "${STACK_DRY_RUN:-0}" == 1 ]]; then
        stack::info "[dry-run] git fetch origin $remote_branch"
    else
        git fetch --quiet origin "$remote_branch"
    fi
fi

git::ref_exists "refs/remotes/$base_ref" \
    || stack::die "base ref refs/remotes/$base_ref does not exist locally (try --no-fetch off, or check origin)"

new_base_sha="$(git rev-parse "refs/remotes/$base_ref")"
recorded_base_sha="$(manifest::get '.base_branch')"

if [[ "$new_base_sha" == "$recorded_base_sha" ]]; then
    stack::ok "base unchanged ($new_base_sha); nothing to sync"
    exit 0
fi

stack_prefix="$(manifest::get '.stack_prefix')"
total="$(jq -r '.branches | length' "$(manifest::path)")"

# Collect old SHAs for the verification step.
old_shas=()
branch_names=()
while IFS=$'\t' read -r order name commit_sha parent; do
    branch_names+=("$name")
    old_shas+=("$commit_sha")
done < <(manifest::branches_in_order)

bottom="${branch_names[0]}"
top="${branch_names[$((total - 1))]}"

{
    echo "base ref:      $base_ref"
    echo "old base:      $recorded_base_sha"
    echo "new base:      $new_base_sha"
    echo "branches:      $bottom .. $top ($total branches)"
    echo "operation:     git branchless move -s $bottom -d $base_ref"
} | prompt::summary_block "stack sync plan"

prompt::confirm "Proceed?" || stack::die "aborted"

# Snapshot every stack branch (and the original feature branch tip).
orig_feat="$(manifest::get '.original_feature_branch')"
snapshot_branches=("${branch_names[@]}")
if git::branch_exists "$orig_feat"; then
    snapshot_branches+=("$orig_feat")
fi

if [[ "${STACK_DRY_RUN:-0}" == 1 ]]; then
    stack::info "[dry-run] would snapshot: ${snapshot_branches[*]}"
    set_id=""
else
    set_id="$(backup::snapshot sync "${snapshot_branches[@]}")"
    stack::ok "snapshot: $set_id"
fi

# Track conflicts during the move.
export STACK_CONFLICTS_SEEN=0

stack::info "running: git branchless move -s $bottom -d $base_ref"
if [[ "${STACK_DRY_RUN:-0}" == 1 ]]; then
    stack::info "[dry-run] skipping move + verification + manifest update"
    exit 0
fi
if ! conflict::drain_during_branchless_move "$bottom" "$base_ref"; then
    stack::err "sync aborted; restoring snapshot"
    backup::restore "$set_id"
    exit 1
fi

# Collect new SHAs.
new_shas=()
for name in "${branch_names[@]}"; do
    new_shas+=("$(git::sha_of "$name")")
done

actual_tip_tree="$(git::tree_of "$top")"

# Verification.
if (( STACK_CONFLICTS_SEEN > 0 )); then
    stack::warn "$STACK_CONFLICTS_SEEN conflict resolution(s) occurred during sync"
    stack::info "new top: $top -> ${new_shas[-1]}"
    stack::info "new top tree: $actual_tip_tree"
    stack::info "rebuilt commit graph (top 8):"
    git log --oneline -8 "$top" >&2
    if ! prompt::confirm "Accept the synced stack?"; then
        stack::err "rejected; restoring snapshot"
        backup::restore "$set_id"
        exit 1
    fi
else
    stack::info "computing reference tip (cherry-picking old commits onto new base)..."
    expected_tree="$(verify::compute_reference_tip "$new_base_sha" "${old_shas[@]}")"
    if [[ "$expected_tree" == "$actual_tip_tree" ]]; then
        stack::ok "verification passed: stack tip tree = $actual_tip_tree"
    else
        stack::err "verification failed: rebuilt tip tree differs from reference"
        stack::err "  expected: $expected_tree"
        stack::err "  actual:   $actual_tip_tree"
        git diff-tree --stat "$expected_tree" "$actual_tip_tree" >&2 || true
        stack::err "restoring snapshot"
        backup::restore "$set_id"
        exit 1
    fi
fi

# Manifest writes.
manifest::set_base_branch "$new_base_sha"
# parent_branch on the bottom branch may have been a SHA; rewrite to the new base SHA.
manifest::set_parent_branch "$bottom" "$new_base_sha"
i=0
for name in "${branch_names[@]}"; do
    manifest::set_branch_sha "$name" "${new_shas[$i]}"
    i=$((i + 1))
done
manifest::record_verification "$actual_tip_tree"

stack::ok "stack sync complete; manifest base updated to $new_base_sha"
stack::info "tip: review 'stack status' and 'git branchless smartlog' before pushing"
