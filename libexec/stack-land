#!/usr/bin/env bash
# stack land: detect that the bottom PR has been merged, drop it from the
# stack, and rebase the rest onto the new base.

set -euo pipefail
IFS=$'\n\t'

: "${STACK_HOME:?stack-land must be invoked via the stack dispatcher}"

# shellcheck source=../lib/common.sh
source "$STACK_HOME/lib/common.sh"
# shellcheck source=../lib/structured.sh
source "$STACK_HOME/lib/structured.sh"
# shellcheck source=../lib/git_helpers.sh
source "$STACK_HOME/lib/git_helpers.sh"
# shellcheck source=../lib/manifest.sh
source "$STACK_HOME/lib/manifest.sh"
# shellcheck source=../lib/branchless.sh
source "$STACK_HOME/lib/branchless.sh"
# shellcheck source=../lib/backup.sh
source "$STACK_HOME/lib/backup.sh"
# shellcheck source=../lib/verify.sh
source "$STACK_HOME/lib/verify.sh"
# shellcheck source=../lib/prompt.sh
source "$STACK_HOME/lib/prompt.sh"
# shellcheck source=../lib/conflict.sh
source "$STACK_HOME/lib/conflict.sh"
# shellcheck source=../lib/az_helpers.sh
source "$STACK_HOME/lib/az_helpers.sh"

usage() {
    cat <<'EOF'
Usage: stack land [--base-ref <ref>] [--no-fetch] [--no-az]

Checks whether the bottom branch's PR has been merged. If so, drops it from
the manifest, deletes its local ref, rebases the rest onto the moved base,
retargets the new bottom's PR via Azure DevOps, and refreshes the PR status
cache.

Options:
  --base-ref <ref>   Override manifest's base_ref (e.g. "origin/master")
  --no-fetch         Skip `git fetch origin`
  --no-az            Skip Azure DevOps detection + retargeting (use git merge-base only)
EOF
}

base_ref_override=''
do_fetch=1
use_az=1
remaining=()
while (( $# > 0 )); do
    case "$1" in
        --base-ref)     shift; base_ref_override="${1:?--base-ref requires a value}" ;;
        --base-ref=*)   base_ref_override="${1#--base-ref=}" ;;
        --no-fetch)     do_fetch=0 ;;
        --no-az)        use_az=0 ;;
        -h|--help)      usage; exit 0 ;;
        *)              remaining+=("$1") ;;
    esac
    shift
done

stack::parse_global_flags "${remaining[@]:-}"
stack::preflight_repo
branchless::preflight
manifest::load

if (( use_az )); then
    az::preflight
    az::resolve_repo
fi

if ! git::working_tree_clean; then
    stack::die "working tree dirty or operation in progress; commit/stash first"
fi

base_ref="$base_ref_override"
[[ -n "$base_ref" ]] || base_ref="$(manifest::base_ref)"
[[ -n "$base_ref" ]] || stack::die "manifest has no base_ref; pass --base-ref"
[[ "$base_ref" == */* ]] || base_ref="origin/$base_ref"
remote_branch="${base_ref#origin/}"

if (( do_fetch )); then
    stack::info "fetching origin/$remote_branch..."
    if [[ "${STACK_DRY_RUN:-0}" == 1 ]]; then
        stack::info "[dry-run] git fetch origin $remote_branch"
    else
        git fetch --quiet origin "$remote_branch"
    fi
fi

bottom_name="$(jq -r '.branches | sort_by(.order) | .[0].name' "$(manifest::path)")"
bottom_sha="$(jq -r '.branches | sort_by(.order) | .[0].commit_sha' "$(manifest::path)")"
bottom_pr_id="$(jq -r '.branches | sort_by(.order) | .[0].pr_id // empty' "$(manifest::path)")"

# Detect merge.
merged=0
if (( use_az )) && [[ -n "$bottom_pr_id" ]]; then
    status="$(az::pr_show "$bottom_pr_id" | jq -r '.status // "unknown"')"
    stack::info "bottom PR #$bottom_pr_id status: $status"
    [[ "$status" == "completed" ]] && merged=1
fi
if (( merged == 0 )); then
    if git::ref_exists "refs/remotes/$base_ref" && git::is_ancestor "$bottom_sha" "refs/remotes/$base_ref"; then
        stack::info "$bottom_name's recorded commit is an ancestor of $base_ref; treating as merged"
        merged=1
    fi
fi

if (( merged == 0 )); then
    stack::ok "bottom branch '$bottom_name' is not yet merged on $base_ref; nothing to land"
    exit 0
fi

total="$(jq -r '.branches | length' "$(manifest::path)")"
if (( total <= 1 )); then
    stack::info "only one branch in the stack; after dropping there is nothing left to rebase"
fi

new_base_sha="$(git rev-parse "refs/remotes/$base_ref")"

# Show the plan.
remaining_lines=()
while IFS=$'\t' read -r order name commit_sha parent; do
    [[ "$name" == "$bottom_name" ]] && continue
    remaining_lines+=("$order"$'\t'"$name"$'\t'"$commit_sha")
done < <(manifest::branches_in_order)

{
    echo "merged bottom: $bottom_name (pr=${bottom_pr_id:-?})"
    echo "new base:      $new_base_sha ($base_ref)"
    if (( ${#remaining_lines[@]} > 0 )); then
        echo "remaining (will rebase + renumber to start at order 1):"
        for ln in "${remaining_lines[@]}"; do
            IFS=$'\t' read -r o n s <<<"$ln"
            printf '  %s  %s  %s\n' "$o" "$n" "${s:0:10}"
        done
        IFS=$'\t' read -r _ first_remaining _ <<<"${remaining_lines[0]}"
        echo "PR retarget:   $first_remaining's PR -> target $remote_branch"
    fi
} | prompt::summary_block "stack land plan"

prompt::confirm "Proceed?" || stack::die "aborted"

# Snapshot.
snapshot_branches=()
while IFS=$'\t' read -r o name sha parent; do
    snapshot_branches+=("$name")
done < <(manifest::branches_in_order)
orig_feat="$(manifest::get '.original_feature_branch')"
git::branch_exists "$orig_feat" && snapshot_branches+=("$orig_feat")

if [[ "${STACK_DRY_RUN:-0}" == 1 ]]; then
    stack::info "[dry-run] would snapshot: ${snapshot_branches[*]}"
    set_id=""
else
    set_id="$(backup::snapshot land "${snapshot_branches[@]}")"
    stack::ok "snapshot: $set_id"
fi

# If we're currently on the bottom branch, switch away first.
cur_branch="$(git::current_branch 2>/dev/null || true)"
if [[ "$cur_branch" == "$bottom_name" ]]; then
    stack::info "currently on $bottom_name; switching to $base_ref before drop"
    if [[ "${STACK_DRY_RUN:-0}" != 1 ]]; then
        git switch --detach "$base_ref" --quiet
    fi
fi

# Delete the merged local branch.
if [[ "${STACK_DRY_RUN:-0}" == 1 ]]; then
    stack::info "[dry-run] git branch -D $bottom_name"
else
    git branch -D "$bottom_name" >/dev/null
fi

# Drop manifest entry + renumber.
if [[ "${STACK_DRY_RUN:-0}" != 1 ]]; then
    manifest::drop_branch "$bottom_name"
    manifest::renumber
fi

# Recompute remaining branch names (now reordered 1..N-1).
remaining_names=()
while IFS=$'\t' read -r order name sha parent; do
    remaining_names+=("$name")
done < <(manifest::branches_in_order)

if (( ${#remaining_names[@]} == 0 )); then
    # Nothing to rebase; finalize manifest.
    if [[ "${STACK_DRY_RUN:-0}" != 1 ]]; then
        manifest::set_base_branch "$new_base_sha"
    fi
    stack::ok "stack land complete; stack is now empty (last branch merged)"
    exit 0
fi

new_bottom="${remaining_names[0]}"
new_top="${remaining_names[$((${#remaining_names[@]} - 1))]}"

# Set the new bottom's parent_branch to the new base SHA.
if [[ "${STACK_DRY_RUN:-0}" != 1 ]]; then
    manifest::set_parent_branch "$new_bottom" "$new_base_sha"
fi

# Rebuild via branchless move (same as sync).
export STACK_CONFLICTS_SEEN=0
stack::info "rebasing remaining stack: git branchless move -s $new_bottom -d $base_ref"
if [[ "${STACK_DRY_RUN:-0}" == 1 ]]; then
    stack::info "[dry-run] skipping move + verification + PR retarget"
    exit 0
fi
if ! conflict::drain_during_branchless_move "$new_bottom" "$base_ref"; then
    stack::err "rebase aborted; restoring snapshot"
    backup::restore "$set_id"
    exit 1
fi

new_top_tree="$(git::tree_of "$new_top")"

# Verification.
if (( STACK_CONFLICTS_SEEN > 0 )); then
    stack::warn "$STACK_CONFLICTS_SEEN conflict resolution(s) occurred during land"
    stack::info "new top: $new_top -> $(git::sha_of "$new_top")"
    stack::info "new top tree: $new_top_tree"
    git log --oneline -8 "$new_top" >&2
    if ! prompt::confirm "Accept the rebased stack?"; then
        stack::err "rejected; restoring snapshot"
        backup::restore "$set_id"
        exit 1
    fi
else
    # Strict check: cherry-pick old commits (excluding the merged bottom)
    # onto the new base and compare.
    old_shas=()
    for n in "${remaining_names[@]}"; do
        old_shas+=("$(jq -r --arg n "$n" '.branches[] | select(.name==$n) | .commit_sha' "$(manifest::path)")")
    done
    stack::info "computing reference tip..."
    expected="$(verify::compute_reference_tip "$new_base_sha" "${old_shas[@]}")"
    if [[ "$expected" == "$new_top_tree" ]]; then
        stack::ok "verification passed: stack tip tree = $new_top_tree"
    else
        stack::err "verification failed; restoring snapshot"
        stack::err "  expected: $expected"
        stack::err "  actual:   $new_top_tree"
        backup::restore "$set_id"
        exit 1
    fi
fi

# Manifest writes: each remaining branch's new commit_sha + base_branch + verification.
manifest::set_base_branch "$new_base_sha"
for n in "${remaining_names[@]}"; do
    manifest::set_branch_sha "$n" "$(git::sha_of "$n")"
done
manifest::record_verification "$new_top_tree"

# Azure DevOps: retarget the new bottom's PR if it has one.
if (( use_az )); then
    new_bottom_pr_id="$(jq -r --arg n "$new_bottom" '.branches[] | select(.name==$n) | .pr_id // empty' "$(manifest::path)")"
    if [[ -n "$new_bottom_pr_id" ]]; then
        stack::info "retargeting PR #$new_bottom_pr_id to $remote_branch"
        az::pr_update "$new_bottom_pr_id" --target "$remote_branch" >/dev/null
    else
        stack::info "new bottom '$new_bottom' has no recorded pr_id; nothing to retarget"
    fi

    # Refresh status cache.
    ids=()
    while IFS=$'\t' read -r order name sha parent; do
        id="$(jq -r --arg n "$name" '.branches[] | select(.name==$n) | .pr_id // empty' "$(manifest::path)")"
        [[ -n "$id" ]] && ids+=("$id")
    done < <(manifest::branches_in_order)
    if (( ${#ids[@]} > 0 )); then
        cache_json="$(az::refresh_status_cache "${ids[@]}")"
        manifest::set_pr_status_cache "$cache_json"
    fi
fi

stack::ok "stack land complete"
stack::info "the old PR for '$bottom_name' is merged (no action needed)"
stack::info "run 'stack push' to push the rebased branches when ready"
