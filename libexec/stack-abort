#!/usr/bin/env bash
# stack abort: restore from a backup snapshot.

set -euo pipefail
IFS=$'\n\t'

: "${STACK_HOME:?stack-abort must be invoked via the stack dispatcher}"

# shellcheck source=../lib/common.sh
source "$STACK_HOME/lib/common.sh"
# shellcheck source=../lib/git_helpers.sh
source "$STACK_HOME/lib/git_helpers.sh"
# shellcheck source=../lib/manifest.sh
source "$STACK_HOME/lib/manifest.sh"
# shellcheck source=../lib/branchless.sh
source "$STACK_HOME/lib/branchless.sh"
# shellcheck source=../lib/backup.sh
source "$STACK_HOME/lib/backup.sh"
# shellcheck source=../lib/prompt.sh
source "$STACK_HOME/lib/prompt.sh"

usage() {
    cat <<'EOF'
Usage: stack abort [--set <set-id>]

Roll back the most recent stack operation by restoring the backup refs it
created. With --set, restore a specific snapshot set (use `stack abort --list`
to inspect available sets).

Options:
  --set <set-id>   Restore this specific set (e.g. refs/backup/stack/foo/update-...)
  --list           Print all snapshot sets and exit without restoring
EOF
}

set_id_arg=''
list_only=0
remaining=()

# Strip our own flags before parse_global_flags sees the args.
while (( $# > 0 )); do
    case "$1" in
        --set)    shift; set_id_arg="${1:?--set requires an argument}" ;;
        --set=*)  set_id_arg="${1#--set=}" ;;
        --list)   list_only=1 ;;
        -h|--help) usage; exit 0 ;;
        *)        remaining+=("$1") ;;
    esac
    shift
done

stack::parse_global_flags "${remaining[@]:-}"
stack::preflight_repo
stack::resolve_manifest
manifest::load

if (( list_only )); then
    sets="$(backup::list_sets || true)"
    if [[ -z "$sets" ]]; then
        stack::info "no backups exist for stack_prefix=$(manifest::get '.stack_prefix')"
        exit 0
    fi
    printf '%s\n' "$sets" | while IFS= read -r set_id; do
        backup::describe "$set_id"
        echo
    done
    exit 0
fi

target_set="$set_id_arg"
if [[ -z "$target_set" ]]; then
    target_set="$(backup::latest_set || true)"
fi

if [[ -z "$target_set" ]]; then
    stack::info "nothing to abort: no backup snapshots exist for stack_prefix=$(manifest::get '.stack_prefix')"
    branchless::undo_hint
    exit 0
fi

stack::info "selected snapshot: $target_set"
backup::describe "$target_set" >&2

if ! prompt::confirm "Restore this snapshot? Local branches listed above will be reset."; then
    stack::info "aborted (no changes)"
    exit 1
fi

if [[ "${STACK_DRY_RUN:-0}" == 1 ]]; then
    stack::info "[dry-run] would restore $target_set"
    exit 0
fi

backup::restore "$target_set"
stack::ok "restore complete"

stack::info "Tip: re-run 'stack status' to confirm the resulting state."
