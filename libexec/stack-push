#!/usr/bin/env bash
# stack push: force-with-lease each stack branch and create/update DevOps PRs.
# Centralized model: the root PR (set once on first push, preserved across
# stack land) holds the canonical Stack: index; non-root PRs carry only a
# back-link to the root.

set -euo pipefail
IFS=$'\n\t'

: "${STACK_HOME:?stack-push must be invoked via the stack dispatcher}"

# shellcheck source=../lib/common.sh
source "$STACK_HOME/lib/common.sh"
# shellcheck source=../lib/git_helpers.sh
source "$STACK_HOME/lib/git_helpers.sh"
# shellcheck source=../lib/manifest.sh
source "$STACK_HOME/lib/manifest.sh"
# shellcheck source=../lib/branchless.sh
source "$STACK_HOME/lib/branchless.sh"
# shellcheck source=../lib/prompt.sh
source "$STACK_HOME/lib/prompt.sh"
# shellcheck source=../lib/az_helpers.sh
source "$STACK_HOME/lib/az_helpers.sh"

usage() {
    cat <<'EOF'
Usage: stack push

Force-with-lease every stack branch to origin and create or update an Azure
DevOps PR per branch. Each PR targets the previous branch in the stack; the
bottom PR targets the manifest's base_ref. The root PR (set once on first
push) carries the canonical stack index in its description; non-root PRs
carry only a back-link to the root PR.
EOF
}

remaining=()
while (( $# > 0 )); do
    case "$1" in
        -h|--help) usage; exit 0 ;;
        *)         remaining+=("$1") ;;
    esac
    shift
done

stack::parse_global_flags "${remaining[@]:-}"
stack::preflight_repo
stack::resolve_manifest
branchless::preflight
manifest::load
az::preflight
az::resolve_repo
az::preflight_auth

base_ref="$(manifest::base_ref)"
if [[ -z "$base_ref" ]]; then
    stack::die "manifest has no base_ref; set one with: jq '.base_ref = \"<branch>\"' \"\$STACK_MANIFEST\" (e.g. \"master\")"
fi
target_for_bottom="${base_ref#origin/}"

stack_prefix="$(manifest::get '.stack_prefix')"

# Root identity. root_pr_id is set on first push and preserved across lands.
root_pr_id="$(manifest::root_pr_id)"
root_pr_url=""

# Designated root branch name. If root_pr_id is already set, find the branch
# in the current manifest whose pr_id matches (empty if the root has been
# landed and removed from branches[]). If root_pr_id is unset, the lowest-
# order branch in the current manifest is the designated root for this push.
if [[ -n "$root_pr_id" ]]; then
    designated_root_name="$(jq -r --arg id "$root_pr_id" '.branches[] | select((.pr_id // "") == $id) | .name' "$(manifest::path)")"
else
    designated_root_name="$(jq -r '.branches | sort_by(.order) | .[0].name' "$(manifest::path)")"
fi

# Plan: <order>\t<name>\t<commit_sha>\t<target>
# Each PR targets the previous branch in the stack; the lowest-order branch
# in the current manifest targets the base_ref.
plan_lines=()
prev_name=''
first=1
while IFS=$'\t' read -r order name commit_sha parent; do
    if (( first )); then
        target="$target_for_bottom"
        first=0
    else
        target="$prev_name"
    fi
    plan_lines+=("$order"$'\t'"$name"$'\t'"$commit_sha"$'\t'"$target")
    prev_name="$name"
done < <(manifest::branches_in_order)

{
    echo "remote:  $AZ_ORG_URL / $AZ_PROJECT / $AZ_REPO"
    if [[ -n "$root_pr_id" ]]; then
        echo "root PR: #$root_pr_id (preserved)"
    else
        echo "root PR: (will be set to $designated_root_name's PR on first creation)"
    fi
    echo "branches (order  name  -> target  recorded_sha):"
    for ln in "${plan_lines[@]}"; do
        IFS=$'\t' read -r o n s t <<<"$ln"
        printf '  %s  %s -> %s  %s\n' "$o" "$n" "$t" "${s:0:10}"
    done
} | prompt::summary_block "stack push plan"

prompt::confirm "Proceed?" || stack::die "aborted"

declare -A pr_ids=()
declare -A pr_urls=()
declare -A pr_decisions=()

push_branch() {
    local branch="$1"
    local local_sha
    local_sha="$(git::sha_of "$branch")"

    local remote_ref="refs/remotes/origin/$branch"
    if git::ref_exists "$remote_ref"; then
        local remote_sha
        remote_sha="$(git rev-parse "$remote_ref")"
        if [[ "$remote_sha" == "$local_sha" ]]; then
            stack::info "$branch: remote matches local; no push"
            return 0
        fi
        stack::info "$branch: force-with-lease push (lease=$remote_sha)"
        if [[ "${STACK_DRY_RUN:-0}" == 1 ]]; then
            stack::info "[dry-run] git push --force-with-lease=refs/heads/$branch:$remote_sha origin $branch"
            return 0
        fi
        git push "--force-with-lease=refs/heads/$branch:$remote_sha" origin "$branch"
    else
        stack::info "$branch: first push"
        if [[ "${STACK_DRY_RUN:-0}" == 1 ]]; then
            stack::info "[dry-run] git push origin $branch"
            return 0
        fi
        git push origin "$branch"
    fi
}

build_root_index() {
    # Markdown list of all branches in the stack. Merged entries get
    # strikethrough; pending PRs are marked. Live PR status comes from ADO
    # (no cache).
    local out=''
    local ln o n s t subject pr_id status merged pr_link
    for ln in "${plan_lines[@]}"; do
        IFS=$'\t' read -r o n s t <<<"$ln"
        subject="$(manifest::branch_field "$n" commit_subject)"
        pr_id="${pr_ids[$n]:-}"
        merged=0
        if [[ -n "$pr_id" && "$pr_id" != "(dry-run)" ]]; then
            status="$(az::pr_show "$pr_id" 2>/dev/null | jq -r '.status // empty' 2>/dev/null || echo)"
            [[ "$status" == "completed" ]] && merged=1
            pr_link="#$pr_id"
        else
            pr_link="(pending)"
        fi
        if (( merged )); then
            out+="- ${o}. ~~${pr_link} - ${subject}~~ (merged)"$'\n'
        else
            out+="- ${o}. ${pr_link} - ${subject}"$'\n'
        fi
    done
    printf '%s' "$out"
}

# render_with_subs <template-path> [KEY VAL ...]: read the template and
# replace each {{KEY}} marker with VAL. Bash parameter expansion handles
# multiline values (e.g., the markdown Stack: list).
render_with_subs() {
    local tmpl="$1"; shift
    [[ -f "$tmpl" ]] || stack::die "PR description template missing: $tmpl"
    local content
    content="$(cat "$tmpl")"
    while (( $# > 0 )); do
        local key="$1" val="$2"
        content="${content//\{\{${key}\}\}/${val}}"
        shift 2
    done
    printf '%s\n' "$content"
}

render_root_description() {
    local subject="$1" body="$2" order="$3"
    local list; list="$(build_root_index)"
    render_with_subs "$STACK_HOME/share/pr-description-root.tmpl" \
        COMMIT_SUBJECT "$subject" \
        COMMIT_BODY    "$body" \
        ORDER          "$order" \
        STACK_LIST     "$list" \
        MANIFEST_PATH  "$STACK_MANIFEST"
}

render_root_landed_description() {
    local list; list="$(build_root_index)"
    render_with_subs "$STACK_HOME/share/pr-description-root-landed.tmpl" \
        STACK_LIST    "$list" \
        MANIFEST_PATH "$STACK_MANIFEST"
}

render_leaf_description() {
    local subject="$1" body="$2" order="$3" root_link="$4"
    render_with_subs "$STACK_HOME/share/pr-description-leaf.tmpl" \
        COMMIT_SUBJECT "$subject" \
        COMMIT_BODY    "$body" \
        ORDER          "$order" \
        ROOT_LINK      "$root_link" \
        MANIFEST_PATH  "$STACK_MANIFEST"
}

build_title() {
    # [Part N] subject. Stable across structural changes (no "of M").
    local order="$1" subject="$2"
    local title="[Part $order] $subject"
    if (( ${#title} > 120 )); then
        title="${title:0:117}..."
    fi
    printf '%s' "$title"
}

build_description_for() {
    # Pick the right template based on whether this branch is the
    # designated root.
    local order="$1" name="$2" subject="$3" body="$4"
    local out_file="$5"
    if [[ "$name" == "$designated_root_name" ]]; then
        render_root_description "$subject" "$body" "$order" > "$out_file"
    else
        local root_link
        if [[ -n "$root_pr_id" ]]; then
            root_link="#$root_pr_id"
        else
            # The root hasn't been created yet in this run. Iteration is
            # by order so this can only happen if the designated root is
            # not in plan_lines (e.g. concurrent edit). Use a safe fallback.
            root_link="(root pending)"
        fi
        render_leaf_description "$subject" "$body" "$order" "$root_link" > "$out_file"
    fi
}

handle_pr_for_branch() {
    local order="$1" name="$2" target="$3"
    local subject body title desc_file tmpd
    subject="$(manifest::branch_field "$name" commit_subject)"
    body="$(manifest::branch_field "$name" commit_body)"
    title="$(build_title "$order" "$subject")"
    tmpd="$(stack::tmpdir)"
    desc_file="$tmpd/desc-$name.md"
    build_description_for "$order" "$name" "$subject" "$body" "$desc_file"

    local existing active_id completed_id abandoned_id
    existing="$(az::pr_list_for_branch "$name")"
    active_id="$(printf '%s' "$existing" | jq -r '.[] | select(.status=="active") | .pullRequestId' | head -1)"
    completed_id="$(printf '%s' "$existing" | jq -r '.[] | select(.status=="completed") | .pullRequestId' | head -1)"
    abandoned_id="$(printf '%s' "$existing" | jq -r '.[] | select(.status=="abandoned") | .pullRequestId' | head -1)"

    if [[ -n "$active_id" ]]; then
        stack::info "$name: updating existing PR #$active_id"
        if [[ "${STACK_DRY_RUN:-0}" == 1 ]]; then
            stack::info "[dry-run] az repos pr update --id $active_id --title ... --description-file ... --target $target"
            pr_ids["$name"]="$active_id"
            pr_urls["$name"]="$(az::pr_url_from_id "$active_id")"
            pr_decisions["$name"]="updated"
            return 0
        fi
        az::pr_update "$active_id" --title "$title" --description-file "$desc_file" --target "$target" > /dev/null
        pr_ids["$name"]="$active_id"
        pr_urls["$name"]="$(az::pr_url_from_id "$active_id")"
        pr_decisions["$name"]="updated"
        return 0
    fi

    if [[ -n "$completed_id" ]]; then
        stack::warn "$name: PR #$completed_id is already merged"
        local choice
        choice="$(prompt::choice "Action for $name (merged PR exists)?" "s/c/a")"
        case "$choice" in
            s) pr_ids["$name"]="$completed_id"; pr_urls["$name"]="$(az::pr_url_from_id "$completed_id")"; pr_decisions["$name"]="skipped"; return 0 ;;
            c) ;;
            a) stack::die "aborted by user" ;;
        esac
    elif [[ -n "$abandoned_id" ]]; then
        stack::warn "$name: PR #$abandoned_id was abandoned"
        local choice
        choice="$(prompt::choice "Action for $name (abandoned PR exists)?" "r/c/a")"
        case "$choice" in
            r)
                if [[ "${STACK_DRY_RUN:-0}" != 1 ]]; then
                    az::pr_update "$abandoned_id" --status active --title "$title" --description-file "$desc_file" --target "$target" >/dev/null
                fi
                pr_ids["$name"]="$abandoned_id"
                pr_urls["$name"]="$(az::pr_url_from_id "$abandoned_id")"
                pr_decisions["$name"]="reactivated"
                return 0
                ;;
            c) ;;
            a) stack::die "aborted by user" ;;
        esac
    fi

    stack::info "$name: creating PR (target $target)"
    if [[ "${STACK_DRY_RUN:-0}" == 1 ]]; then
        stack::info "[dry-run] az repos pr create --source $name --target $target --title \"$title\""
        pr_ids["$name"]="(dry-run)"
        pr_urls["$name"]="(dry-run)"
        pr_decisions["$name"]="created"
        return 0
    fi
    local created_json new_id new_url
    created_json="$(az::pr_create "$name" "$target" "$title" "$desc_file")"
    new_id="$(printf '%s' "$created_json" | jq -r '.pullRequestId')"
    new_url="$(az::pr_url_from_id "$new_id")"
    pr_ids["$name"]="$new_id"
    pr_urls["$name"]="$new_url"
    pr_decisions["$name"]="created"
}

# Pass 1: push + create/update each PR.
for ln in "${plan_lines[@]}"; do
    IFS=$'\t' read -r o n s t <<<"$ln"
    push_branch "$n"
    handle_pr_for_branch "$o" "$n" "$t"
    if [[ "${STACK_DRY_RUN:-0}" != 1 && -n "${pr_ids[$n]:-}" ]]; then
        manifest::set_pr "$n" "${pr_ids[$n]}" "${pr_urls[$n]}"
        # Record root identity on first creation of the designated root branch.
        if [[ -z "$root_pr_id" && "$n" == "$designated_root_name" && "${pr_ids[$n]}" != "(dry-run)" ]]; then
            root_pr_id="${pr_ids[$n]}"
            root_pr_url="${pr_urls[$n]}"
            manifest::set_root_pr "$root_pr_id" "$root_pr_url"
            stack::info "recorded root PR: #$root_pr_id"
        fi
    fi
done

# Final: update the root PR's description with the canonical Stack: list
# (now that every PR id is known). Single PR update, not a stack-wide pass.
if [[ "${STACK_DRY_RUN:-0}" != 1 && -n "$root_pr_id" ]]; then
    stack::info "refreshing root PR #$root_pr_id with canonical stack index"
    tmpd="$(stack::tmpdir)"
    desc_file="$tmpd/desc-root-final.md"
    if [[ -n "$designated_root_name" ]]; then
        root_order="$(manifest::branch_field "$designated_root_name" order)"
        root_subject="$(manifest::branch_field "$designated_root_name" commit_subject)"
        root_body="$(manifest::branch_field "$designated_root_name" commit_body)"
        render_root_description "$root_subject" "$root_body" "$root_order" > "$desc_file"
    else
        # Root branch was landed; refresh description with landed template.
        render_root_landed_description > "$desc_file"
    fi
    az::pr_update "$root_pr_id" --description-file "$desc_file" >/dev/null
fi

stack::ok "stack push complete"
{
    echo "PRs:"
    for ln in "${plan_lines[@]}"; do
        IFS=$'\t' read -r o n s t <<<"$ln"
        printf '  %s  %s [%s]  %s\n' "$o" "$n" "${pr_decisions[$n]:-?}" "${pr_urls[$n]:-?}"
    done
    if [[ -n "$root_pr_id" ]]; then
        printf '  root: #%s\n' "$root_pr_id"
    fi
} >&2
